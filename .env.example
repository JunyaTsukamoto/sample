# ===== きづき 環境変数（値はコミットしないこと。ここには変数名のみ） =====
# タイムゾーン（既定: Asia/Tokyo）
APP_TIMEZONE=Asia/Tokyo

# 本番でモックデータを使うか。true の場合、本番ビルドは失敗します（必ず false）
USE_MOCK_DATA=false

# 要約用 LLM（任意）。未設定でも抽出要約で動作します。
GEMINI_API_KEY=
OPENAI_API_KEY=

# ニュースAPI（任意）。未設定の情報源は自動的に無効化されます。
NEWS_API_KEY=

# 収集エンドポイントを外部から保護する共有シークレット（任意）
CRON_SECRET=

# データベースURL（既定はファイルDBのため未使用。将来のDB移行用）
DATABASE_URL=
